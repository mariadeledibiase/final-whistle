<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126038.ui.MatchController"
      spacing="14"
      alignment="CENTER"
      style="-fx-background-color: #f5f5f5; -fx-padding: 24;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-background-radius: 14;
                 -fx-effect: dropshadow(gaussian, #e0e0e0, 8, 0, 0, 2);">
        <Label fx:id="lblMatchTitle"
               text=""
               style="-fx-font-size: 16; -fx-text-fill: #888; -fx-font-weight: bold;"/>
        <Label fx:id="lblScore"
               text="? - ?"
               style="-fx-font-size: 52; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
        <Label fx:id="lblTactic"
               text=""
               style="-fx-font-size: 12; -fx-text-fill: #2e7d32; -fx-font-weight: bold;"/>
    </VBox>

    <!-- Risultato -->
    <Label fx:id="lblResult"
           text=""
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>

    <!-- Cronaca -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 16;
                              -fx-background-radius: 12;
                              -fx-effect: dropshadow(gaussian, #e0e0e0, 6, 0, 0, 2);">
        <Label text="CRONACA"
               style="-fx-font-size: 11; -fx-font-weight: bold;
                      -fx-text-fill: #2e7d32; -fx-letter-spacing: 1;"/>
        <ListView fx:id="lstEvents"
                  style="-fx-min-height: 180; -fx-font-size: 13;
                         -fx-border-color: #eeeeee; -fx-border-radius: 8;"/>
    </VBox>

    <!-- Tattica -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 14;
                              -fx-background-radius: 12;
                              -fx-effect: dropshadow(gaussian, #e0e0e0, 6, 0, 0, 2);">
        <Label text="CAMBIA TATTICA"
               style="-fx-font-size: 11; -fx-font-weight: bold;
                      -fx-text-fill: #888; -fx-letter-spacing: 1;"/>
        <HBox spacing="10" alignment="CENTER">
            <Button text="Offensiva"
                    onAction="#onSetOffensive"
                    style="-fx-background-color: #ffebee; -fx-text-fill: #c62828;
                           -fx-font-weight: bold; -fx-min-width: 120; -fx-padding: 9;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="Difensiva"
                    onAction="#onSetDefensive"
                    style="-fx-background-color: #e3f2fd; -fx-text-fill: #1565c0;
                           -fx-font-weight: bold; -fx-min-width: 120; -fx-padding: 9;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="Bilanciata"
                    onAction="#onSetBalanced"
                    style="-fx-background-color: #fff8e1; -fx-text-fill: #f57f17;
                           -fx-font-weight: bold; -fx-min-width: 120; -fx-padding: 9;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- Pulsanti -->
    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="btnPlay"
                text="Gioca la Partita"
                onAction="#onPlayMatch"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white;
                       -fx-min-width: 200; -fx-padding: 13; -fx-background-radius: 10;
                       -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"/>
        <Button fx:id="btnContinue"
                text="Continua"
                onAction="#onContinue"
                style="-fx-background-color: #1565c0; -fx-text-fill: white;
                       -fx-min-width: 200; -fx-padding: 13; -fx-background-radius: 10;
                       -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"/>
    </HBox>

</VBox>