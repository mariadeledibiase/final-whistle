<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126038.ui.MainController"
      spacing="24"
      alignment="CENTER"
      style="-fx-background-color: #f5f5f5; -fx-padding: 60;">

    <!-- Logo -->
    <VBox alignment="CENTER" spacing="6"
          style="-fx-background-color: white; -fx-padding: 36;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, #e0e0e0, 10, 0, 0, 3);">
        <Label text="FINAL WHISTLE"
               style="-fx-font-size: 40; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
        <Label text="Il torneo a eliminazione diretta"
               style="-fx-font-size: 14; -fx-text-fill: #888888;"/>

        <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
            <Button fx:id="btnNewGame"
                    text="Nuova Partita"
                    onAction="#onNewGame"
                    style="-fx-font-size: 15; -fx-font-weight: bold;
                           -fx-background-color: #2e7d32; -fx-text-fill: white;
                           -fx-min-width: 280; -fx-padding: 14;
                           -fx-background-radius: 10; -fx-cursor: hand;"/>
            <Button text="Esci"
                    onAction="#onExit"
                    style="-fx-font-size: 14; -fx-background-color: #eeeeee;
                           -fx-text-fill: #555; -fx-min-width: 280; -fx-padding: 12;
                           -fx-background-radius: 10; -fx-cursor: hand;"/>
        </VBox>
    </VBox>

</VBox>